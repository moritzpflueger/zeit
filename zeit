def cmd_list(_args):
    config = load_config()
    currency = get_currency(config)
    projects = config.get("projects", {})
    if not projects:
        print("No projects configured.")
        return
    # Group by label
    by_label = {}
    for prefix, entry in projects.items():
        if isinstance(entry, dict):
            label = entry.get("label", prefix)
            rate = entry.get("rate", 0)
        else:
            label = entry
            rate = 0
        by_label.setdefault(label, {"dirs": [], "rate": rate})
        by_label[label]["dirs"].append(prefix)
    for label in sorted(by_label):
        info = by_label[label]
        rate_str = f"  ({info['rate']} {currency}/h)" if info["rate"] and currency else ""
        real_dirs = [d for d in info["dirs"] if not d.startswith("__imported__")]
        c = project_color(label)
        print(f"  {c}{label}{RESET}{rate_str}")
        for d in sorted(real_dirs):
            print(f"    {d}")


def cmd_sync(_args):
    git_sync("manual sync")


HELP = f"""{LOGO}
simple time logger

  zeit <hours> [date] [description]   Log hours (default: today)
  zeit <hours> <start>..<end> [desc]  Log hours for a date range
  zeit sum [month] [project]          Show entries + total (auto-filters by cwd)
  zeit sum march all                  Show all projects for a month
  zeit last [n]                       Show last n entries (default: 10)
  zeit status                         Activity overview for the current month
  zeit undo                           Remove last entry
  zeit rm <date>                      Remove entries on a specific date
  zeit edit                           Open log in $EDITOR
  zeit list                           Show projects with directories and rates
  zeit sync                           Manual GitHub sync
  zeit init                           First-time setup
  zeit config                         Change settings
  zeit -h                             Show this help
  zeit --version                      Show version

Date formats:
  today, yesterday, -2 (days ago), monday, 03-28, 2026-03-28

Month filters for sum:
  zeit sum april | zeit sum 04 | zeit sum 2026-04 | zeit sum all
""".rstrip()


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(HELP)
        return

    if args[0] in ("-v", "--version"):
        print(f"zeit {VERSION}")
        return

    cmd = args[0]

    # Commands that work without config
    unchecked = {"init": cmd_init}

    if cmd in unchecked:
        unchecked[cmd](args[1:])
        return

    # Everything else requires config
    if not is_configured():
        print("zeit is not configured yet. Run `zeit init` to get started.")
        return

    commands = {
        "sum": cmd_sum,
        "undo": cmd_undo,
        "rm": cmd_rm,
        "edit": cmd_edit,
        "list": cmd_list,
        "last": cmd_last,
        "status": cmd_status,
        "sync": cmd_sync,
        "config": cmd_config,
    }

    if cmd in commands:
        commands[cmd](args[1:])
        return

    # Default: log hours
    try:
        float(args[0])
    except ValueError:
        print(f"Unknown command: {cmd}")
        print("Run 'zeit -h' for help.")
        return

    cmd_log_hours(args)


if __name__ == "__main__":
    main()
