def cmd_undo(_args):
    entries = load_entries()
    if not entries:
        print("No entries.")
        return
    last = entries[-1]
    desc_str = f"  {last['desc']}" if last.get("desc") else ""
    c = project_color(last['project'])
    print(f"Last entry: {last['date']}  {last['hours']}h  {c}{last['project']}{RESET}{desc_str}")
    try:
        confirm = input("Remove? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return
    if confirm == "y":
        entries.pop()
        save_entries(entries)
        print("Removed.")
        git_sync("undo last entry")


def cmd_rm(args):
    if not args:
        print("Usage: zeit rm <date>")
        print("  zeit rm today | zeit rm yesterday | zeit rm 2026-04-01")
        return

    target = parse_date(args[0])
    target_iso = target.isoformat()
    entries = load_entries()
    matches = [(i, e) for i, e in enumerate(entries) if e["date"] == target_iso]

    if not matches:
        print(f"No entries on {target_iso}.")
        return

    try:
        if len(matches) == 1:
            i, e = matches[0]
            desc_str = f"  {e['desc']}" if e.get("desc") else ""
            print(f"  {e['hours']}h  {e['project']}{desc_str}")
            confirm = input("Remove? [y/N] ").strip().lower()
            if confirm != "y":
                return
            to_remove = {i}
        else:
            print(f"\n{len(matches)} entries on {target_iso}:\n")
            for j, (i, e) in enumerate(matches, 1):
                desc_str = f"  {e['desc']}" if e.get("desc") else ""
                print(f"  {j}. {e['hours']}h  {e['project']}{desc_str}")
            print(f"  0. All")
            print()
            choice = input("Remove which? (or Enter to cancel): ").strip()
            if not choice:
                return
            idx = int(choice)
            if idx == 0:
                to_remove = {i for i, _ in matches}
            elif 1 <= idx <= len(matches):
                to_remove = {matches[idx - 1][0]}
            else:
                print("Invalid choice.")
                return
    except (EOFError, KeyboardInterrupt):
        print()
        return

    new_entries = [e for i, e in enumerate(entries) if i not in to_remove]
    save_entries(new_entries)
    count = len(to_remove)
    print(f"Removed {count} {'entry' if count == 1 else 'entries'}.")
    git_sync(f"rm {count} entries on {target_iso}")


